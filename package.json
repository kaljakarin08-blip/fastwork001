{
  "name": "law-content-v2",
  "version": "0.1.0",
  "private": true,
  "description": "AI Content OS for Law Firms",
  "author": "Jakarin",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "hermes": "tsx hermes/worker.ts",
    "telegram": "tsx hermes/telegram.ts",
    "rag:index": "tsx rag/scripts/index-vault.ts",
    "electron:rebuild": "npx @electron/rebuild -f -w better-sqlite3",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "hermes:build": "esbuild hermes/worker.ts --bundle --platform=node --outfile=dist/hermes.js --external:better-sqlite3 --external:node-telegram-bot-api",
    "build:electron": "next build && node scripts/prepare-standalone.js && pnpm hermes:build && pnpm electron:compile",
    "dist:mac": "pnpm build:electron && electron-builder --mac",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && NODE_ENV=development electron .\"",
    "mcp:start": "tsx mcp/server.ts",
    "mcp:daemon": "tsx mcp/daemon.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^6.42.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "pdfjs-dist": "^4.10.38",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/node-telegram-bot-api": "^0.64.15",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.5",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "wait-on": "^8.0.3"
  }
}
